{
  "name": "tur-antlr",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "antlr4ts -visitor -no-listener -o src/generated grammar/TurLang.g4",
    "typecheck": "tsc -p tsconfig.json",
    "parse": "bun run src/parse.ts",
    "run": "bun run src/run.ts"
  },
  "dependencies": {
    "antlr4ts": "^0.5.0-alpha.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "antlr4ts-cli": "^0.5.0-alpha.4",
    "typescript": "^5.8.3"
  }
}
